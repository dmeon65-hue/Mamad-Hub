local function createGradient(parent, c1, c2, rot)
    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new({ColorSequenceKeypoint.new(0,c1),ColorSequenceKeypoint.new(1,c2)})
    g.Rotation = rot or 135
    g.Parent = parent
    return g
end

local function applyGlow(frame, color)
    local s = Instance.new("UIStroke")
    s.Color = color
    s.Thickness = 1.5
    s.Parent = frame
    return s
end

local function makeDraggable(frame, handle)
    local h = handle or frame
    local dragging = false
    local dragStart, startPos

    h.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)

    h.InputChanged:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMove) and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset+delta.X, startPos.Y.Scale, startPos.Y.Offset+delta.Y)
        end
    end)
end

local function showNotif(text, color, duration)
    table.insert(notifQueue, {text=text, color=color or getTheme().accent, duration=duration or 2.5})
    if isNotifShowing then return end
    isNotifShowing = true
    coroutine.wrap(function()
        while #notifQueue > 0 do
            local data = table.remove(notifQueue, 1)
            local nf = Instance.new("Frame")
            nf.Size = UDim2.new(0, 240, 0, 44)
            nf.Position = UDim2.new(0.5, -120, 0, -60)
            nf.BackgroundColor3 = Color3.fromRGB(8, 0, 28)
            nf.BorderSizePixel = 0
            nf.ZIndex = 50
            nf.Parent = ScreenGui
            Instance.new("UICorner", nf).CornerRadius = UDim.new(0, 12)
            applyGlow(nf, data.color)
            createGradient(nf, Color3.fromRGB(15,0,45), Color3.fromRGB(40,0,75))

            local bar = Instance.new("Frame")
            bar.Size = UDim2.new(0, 4, 1, -10)
            bar.Position = UDim2.new(0, 6, 0, 5)
            bar.BackgroundColor3 = data.color
            bar.BorderSizePixel = 0
            bar.ZIndex = 51
            bar.Parent = nf
            Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 4)

            local nl = Instance.new("TextLabel")
            nl.Size = UDim2.new(1, -22, 1, 0)
            nl.Position = UDim2.new(0, 18, 0, 0)
            nl.BackgroundTransparency = 1
            nl.Text = text
            nl.TextColor3 = Color3.fromRGB(230, 210, 255)
            nl.TextSize = 12
            nl.Font = Enum.Font.GothamBold
            nl.TextXAlignment = Enum.TextXAlignment.Left
            nl.ZIndex = 51
            nl.Parent = nf

            TweenService:Create(nf, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {Position=UDim2.new(0.5,-120,0,12)}):Play()
            wait(data.duration)
            TweenService:Create(nf, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {Position=UDim2.new(0.5,-120,0,-60)}):Play()
            wait(0.35)
            nf:Destroy()
        end
        isNotifShowing = false
    end)()
end

local function makeBtn(parent, text, xOff, w, color, h)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, w or 38, 0, h or 22)
    btn.Position = UDim2.new(0, xOff, 0.5, -((h or 22)/2))
    btn.BackgroundColor3 = color or Color3.fromRGB(60, 0, 140)
    btn.BorderSizePixel = 0
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 9
    btn.Font = Enum.Font.GothamBold
    btn.ZIndex = 8
    btn.Parent = parent
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundTransparency=0.3}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundTransparency=0}):Play()
    end)

    return btn
end

