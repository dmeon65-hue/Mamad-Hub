local function refreshList()
    for _, c in pairs(PlayersScroll:GetChildren()) do
        if c:IsA("Frame") or (c:IsA("TextLabel") and c ~= nil) then
            if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then
                c:Destroy()
            end
        end
    end
    playerRows = {}

    local plrList = Players:GetPlayers()
    table.sort(plrList, function(a, b)
        local af = favoritesList[a.Name] and 1 or 0
        local bf = favoritesList[b.Name] and 1 or 0
        if af ~= bf then return af > bf end
        return a.Name < b.Name
    end)

    local secL = Instance.new("TextLabel")
    secL.Size = UDim2.new(1, 0, 0, 22)
    secL.BackgroundTransparency = 1
    secL.Text = "  ✦ Players Online (" .. #plrList .. ")"
    secL.TextColor3 = getTheme().accent
    secL.TextSize = 11
    secL.Font = Enum.Font.GothamBold
    secL.TextXAlignment = Enum.TextXAlignment.Left
    secL.ZIndex = 7
    secL.Parent = PlayersScroll

    for _, p in pairs(plrList) do
        if searchText == "" or string.lower(p.Name):find(string.lower(searchText)) then
            playerRows[p.Name] = createPlayerRow(p)
        end
    end
end

