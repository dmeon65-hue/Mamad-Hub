local function addESPToPlayer(player)
    if player == LocalPlayer then return end
    local char = player.Character
    if not char then return end

    if espHighlights[player.Name] then espHighlights[player.Name]:Destroy() end
    if espBillboards[player.Name] then espBillboards[player.Name]:Destroy() end

    local hl = Instance.new("Highlight")
    hl.Adornee = char
    hl.FillColor = getTheme().primary
    hl.OutlineColor = getTheme().accent
    hl.FillTransparency = espChamsActive and 0 or 0.5
    hl.OutlineTransparency = 0
    hl.Parent = char
    espHighlights[player.Name] = hl

    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then
        local bb = Instance.new("BillboardGui")
        bb.Size = UDim2.new(0, 130, 0, 50)
        bb.StudsOffset = Vector3.new(0, 4.5, 0)
        bb.Adornee = hrp
        bb.AlwaysOnTop = true
        bb.Parent = hrp

        local nameL = Instance.new("TextLabel")
        nameL.Size = UDim2.new(1, 0, 0.5, 0)
        nameL.BackgroundTransparency = 1
        nameL.Text = "✦ " .. player.Name
        nameL.TextColor3 = getTheme().accent
        nameL.TextSize = 13
        nameL.Font = Enum.Font.GothamBold
        nameL.TextStrokeTransparency = 0
        nameL.Parent = bb

        local distL = Instance.new("TextLabel")
        distL.Size = UDim2.new(1, 0, 0.25, 0)
        distL.Position = UDim2.new(0, 0, 0.5, 0)
        distL.BackgroundTransparency = 1
        distL.Text = "-- studs"
        distL.TextColor3 = Color3.fromRGB(180, 255, 180)
        distL.TextSize = 10
        distL.Font = Enum.Font.Gotham
        distL.TextStrokeTransparency = 0
        distL.Parent = bb
        espDistanceLabels[player.Name] = distL

        local hpL = Instance.new("TextLabel")
        hpL.Size = UDim2.new(1, 0, 0.25, 0)
        hpL.Position = UDim2.new(0, 0, 0.75, 0)
        hpL.BackgroundTransparency = 1
        hpL.Text = "HP: --"
        hpL.TextColor3 = Color3.fromRGB(255, 150, 150)
        hpL.TextSize = 10
        hpL.Font = Enum.Font.Gotham
        hpL.TextStrokeTransparency = 0
        hpL.Parent = bb
        espHealthLabels[player.Name] = hpL

        espBillboards[player.Name] = bb
    end
end

local function removeESPFromPlayer(player)
    if espHighlights[player.Name] then
        espHighlights[player.Name]:Destroy()
        espHighlights[player.Name] = nil
    end
    if espBillboards[player.Name] then
        espBillboards[player.Name]:Destroy()
        espBillboards[player.Name] = nil
    end
    espDistanceLabels[player.Name] = nil
    espHealthLabels[player.Name] = nil
end

