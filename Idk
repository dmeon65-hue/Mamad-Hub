RunService.RenderStepped:Connect(function(dt)
    shimmerValue = shimmerValue + dt * 0.7
    local a = (math.sin(shimmerValue) + 1) / 2
    local theme = getTheme()
    local glowColor = theme.glow
    mainStroke.Color = Color3.fromRGB(
        math.clamp(math.floor(glowColor.R*255 + a*40), 0, 255),
        math.clamp(math.floor(glowColor.G*255 + a*20), 0, 255),
        math.clamp(math.floor(glowColor.B*255 + a*30), 0, 255)
    )
    toggleStroke.Color = mainStroke.Color

    local myChar = LocalPlayer.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    local myHum = myChar and myChar:FindFirstChildOfClass("Humanoid")

    if myHum then
        speedVal.Text = math.round(myHum.WalkSpeed) .. " ws"
        jumpVal.Text = tostring(math.round(myHum.JumpPower))
    end

    for name, dl in pairs(espDistanceLabels) do
        local p = Players:FindFirstChild(name)
        if p and p.Character then
            local tHRP = p.Character:FindFirstChild("HumanoidRootPart")
            if tHRP and myHRP then
                dl.Text = math.round((myHRP.Position - tHRP.Position).Magnitude) .. " studs"
            end
        end
    end

    for name, hl in pairs(espHealthLabels) do
        local p = Players:FindFirstChild(name)
        if p and p.Character then
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if hum then
                local hp = math.round(hum.Health)
                local maxhp = math.round(hum.MaxHealth)
                hl.Text = "HP: " .. hp .. "/" .. maxhp
                local ratio = hp / math.max(maxhp, 1)
                hl.TextColor3 = Color3.fromRGB(math.floor(255*(1-ratio)), math.floor(255*ratio), 80)
            end
        end
    end

    frameCount = frameCount + 1
    if tick() - lastFrameTime >= 0.5 then
        currentFPS = math.round(frameCount / (tick() - lastFrameTime))
        frameCount = 0
        lastFrameTime = tick()
        if fpsLabel then
            fpsLabel.Text = currentFPS .. " fps"
            if currentFPS >= 55 then
                fpsLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
            elseif currentFPS >= 30 then
                fpsLabel.TextColor3 = Color3.fromRGB(255, 200, 50)
            else
                fpsLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
            end
        end
    end

    if minimapEnabled and myHRP then
        for _, old in pairs(minimapDots) do old:Destroy() end
        minimapDots = {}

        local meDot = Instance.new("Frame")
        meDot.Size = UDim2.new(0, 8, 0, 8)
        meDot.AnchorPoint = Vector2.new(0.5, 0.5)
        meDot.Position = UDim2.new(0.5, 0, 0.5, 0)
        meDot.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
        meDot.BorderSizePixel = 0
        meDot.ZIndex = 17
        meDot.Parent = MinimapFrame
        Instance.new("UICorner", meDot).CornerRadius = UDim.new(1, 0)
        table.insert(minimapDots, meDot)

        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local tHRP = p.Character:FindFirstChild("HumanoidRootPart")
                if tHRP then
                    local diff = tHRP.Position - myHRP.Position
                    local scale = 1/100
                    local rx = math.clamp(0.5 + diff.X * scale, 0.05, 0.95)
                    local ry = math.clamp(0.5 + diff.Z * scale, 0.05, 0.95)

                    local dot = Instance.new("Frame")
                    dot.Size = UDim2.new(0, 6, 0, 6)
                    dot.AnchorPoint = Vector2.new(0.5, 0.5)
                    dot.Position = UDim2.new(rx, 0, ry, 0)
                    dot.BackgroundColor3 = getTheme().accent
                    dot.BorderSizePixel = 0
                    dot.ZIndex = 17
                    dot.Parent = MinimapFrame
                    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

                    local nameTag = Instance.new("TextLabel")
                    nameTag.Size = UDim2.new(0, 50, 0, 12)
                    nameTag.Position = UDim2.new(0.5, 0, 0, 0)
                    nameTag.BackgroundTransparency = 1
                    nameTag.Text = p.Name
                    nameTag.TextColor3 = Color3.fromRGB(255, 255, 255)
                    nameTag.TextSize = 8
                    nameTag.Font = Enum.Font.Gotham
                    nameTag.ZIndex = 18
                    nameTag.Parent = dot

                    table.insert(minimapDots, dot)
                end
            end
        end
    end
end)

